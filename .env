BROKER_TYPE=kafka
SYSTEM_NAMESPACE=
SPRING_KAFKA_PROPERTIES_SECURITY_PROTOCOL=SASL_PLAINTEXT
SPRING_KAFKA_PROPERTIES_SASL_MECHANISM=PLAIN
SPRING_KAFKA_PROPERTIES_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username=\"${BROKER_USER:-admin}\" password=\"${BROKER_PASSWORD:-admin_secret_123}\";